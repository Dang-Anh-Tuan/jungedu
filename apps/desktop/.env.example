# Ảnh → chữ: puter | openai (mặc định puter — vision AI qua Puter.js)
VITE_IMAGE_TO_TEXT_PROVIDER=puter
VITE_PUTER_VISION_MODEL=gpt-4o-mini

# Chấm bài AI (Puter — JSON cleanup + rubric; tách model nếu cần)
VITE_PUTER_CLEANUP_MODEL=gpt-4o-mini
VITE_PUTER_GRADING_MODEL=gpt-4o-mini

# Chỉ khi VITE_IMAGE_TO_TEXT_PROVIDER=openai — không commit key thật; production nên gọi API qua backend.
