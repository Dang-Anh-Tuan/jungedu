# Config firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=


# Ảnh bài làm (đồng bộ điện thoại ↔ máy tính):
# - firebase (mặc định nếu không set): Firebase Storage.
# - gdrive: Google Drive — cần OAuth Client ID + bật Google Drive API (xem hướng dẫn dưới).
# - local: chỉ IndexedDB một trình duyệt — không đồng bộ giữa thiết bị.
VITE_SUBMISSION_IMAGE_STORAGE=

# --- Google Drive (chỉ khi VITE_SUBMISSION_IMAGE_STORAGE=gdrive) ---
# Upload ảnh dùng OAuth trong trình duyệt, KHÔNG dùng “API key” đơn thuần.
# Bạn cần OAuth 2.0 Client ID kiểu “Ứng dụng web” (Web application), không phải API key cho REST Drive.
VITE_GOOGLE_OAUTH_CLIENT_ID=
# Tùy chọn: id thư mục Drive (chuỗi sau /folders/ trong URL). Để trống = file nằm ở “My Drive” của tài khoản đăng nhập.
VITE_GOOGLE_DRIVE_UPLOAD_FOLDER_ID=
VITE_PUTER_GRADING_MODEL=
VITE_PUTER_VISION_MODEL=
VITE_GEMINI_API_KEY=
# Hướng dẫn lấy OAuth Client ID (Google Cloud Console):
# 1. Vào https://console.cloud.google.com/ → chọn hoặc tạo project.
# 2. APIs & Services → Library → bật “Google Drive API”.
# 3. APIs & Services → OAuth consent screen → chọn User type (External/Internal), điền tên app, lưu.
# 4. APIs & Services → Credentials → Create credentials → OAuth client ID → Application type: Web application.
# 5. Authorized JavaScript origins: thêm URL frontend (vd http://localhost:5173 và URL production).
#    Authorized redirect URIs thường để trống cho GIS token flow trong SPA (hoặc theo gợi ý của Console).
# 6. Copy “Client ID” (dạng ...apps.googleusercontent.com) vào VITE_GOOGLE_OAUTH_CLIENT_ID.
# 7. Trên trang Nhập bài làm, bấm “Kết nối Google Drive” và chấp nhận quyền (scope drive.file — chỉ file app tạo).your_api_key